{
  "domains": ["keraos.cc", "work-universe.vercel.app"],
  "functions": {
    "api/anthropic.js": { "maxDuration": 60 },
    "api/inbound.js": { "maxDuration": 30 },
    "api/calendar.js": { "maxDuration": 30 },
    "api/invoices.js": { "maxDuration": 30 },
    "api/ai-brain.js": { "maxDuration": 60 }
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/ai-brain",
      "schedule": "0 9 * * *"
    }
  ]
}
